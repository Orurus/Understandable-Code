import tensor_matrix_library
import advanced_ml_library
import stdlib

// -------------------------
// Create training data
// -------------------------

inputs = tensor_matrix_library.new_matrix_with_random_values(5, 1, 0, 1)
targets = inputs

// -------------------------
// Create model weights
// -------------------------

weights = advanced_ml_library.create_neural_network_layer_with_random_weights(1, 1)
bias = advanced_ml_library.create_neural_network_bias_vector(1)

// -------------------------
// Training loop
// -------------------------

learning_rate = 0.1
epoch = 0

loop while epoch is smaller than 10

    // forward pass (linear model)
    predictions = tensor_matrix_library.multiply_matrix_by_matrix(inputs, weights)

    // loss
    loss = advanced_ml_library.compute_mean_squared_error(predictions, targets)

    say("Epoch " + convert_to_txt(epoch))
    say("Loss: " + convert_to_txt(loss))

    // gradient (simple approximation step)
    gradients = advanced_ml_library.create_weight_update_using_error_signal(
        weights,
        targets,
        learning_rate
    )

    // update weights
    weights = advanced_ml_library.create_gradient_descent_optimization_step(
        weights,
        gradients,
        learning_rate
    )

    epoch = epoch + 1
end

say("Training complete")